PULLSING_APP_NAME=pullsing-server
PULLSING_ENV=development
PULLSING_HTTP_ADDR=:8080
PULLSING_GRPC_ADDR=:50051
PULLSING_GRPC_CLIENT_BUFFER=16
PULLSING_HTTP_READ_TIMEOUT=5s
PULLSING_HTTP_READ_HEADER_TIMEOUT=3s
PULLSING_HTTP_WRITE_TIMEOUT=10s
PULLSING_HTTP_IDLE_TIMEOUT=30s
PULLSING_SHUTDOWN_TIMEOUT=10s
PULLSING_POSTGRES_URL=postgres://pullsing:pullsing@localhost:5432/pullsing?sslmode=disable
PULLSING_REDIS_ADDR=localhost:6379
